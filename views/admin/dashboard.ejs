<%- include('../partials/layout-top') %>
<section>
  <div class="page-head">
    <h1>Dashboard · Admin</h1>
    <div class="actions">
      <a class="btn" href="/dashboard">Painel</a>
      <a class="btn" href="/sales">Vendas</a>
    </div>
  </div>

  <p class="muted">
    Vendas por data dos últimos dias em que houve abertura de caixa.
  </p>

  <form method="get" action="/admin/dashboard" class="filter-bar">
    <label>Últimos dias com abertura
      <select name="days">
        <option value="7" <%= limit === 7 ? 'selected' : '' %>>7 dias</option>
        <option value="14" <%= limit === 14 ? 'selected' : '' %>>14 dias</option>
        <option value="30" <%= limit === 30 ? 'selected' : '' %>>30 dias</option>
      </select>
    </label>
    <button class="btn primary" type="submit">Atualizar</button>
  </form>

  <div class="stats">
    <div class="stat">
      <span class="label">Dias com abertura</span>
      <strong><%= totals.days_count %></strong>
    </div>
    <div class="stat">
      <span class="label">Vendas no período</span>
      <strong><%= totals.sales_count %></strong>
    </div>
    <div class="stat">
      <span class="label">Total vendido</span>
      <strong><%= formatMoney(totals.total_cents) %></strong>
    </div>
    <div class="stat">
      <span class="label">PIX · Dinheiro · Fiado</span>
      <strong style="font-size:1rem"><%= formatMoney(totals.pix_cents) %></strong>
      <small><%= formatMoney(totals.cash_cents) %> · <%= formatMoney(totals.credit_cents) %></small>
    </div>
  </div>

  <% if (!points.length) { %>
  <p class="muted">Nenhuma abertura de caixa encontrada para montar o gráfico.</p>
  <% } else { %>
  <div class="chart-panel">
    <h2>Vendas por data</h2>
    <div class="chart-wrap">
      <canvas id="salesByOpeningChart" aria-label="Gráfico de vendas por data de abertura de caixa"></canvas>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Data</th>
        <th>Aberturas</th>
        <th>Vendas</th>
        <th>PIX</th>
        <th>Dinheiro</th>
        <th>Fiado</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <% [...points].reverse().forEach(p => { %>
      <tr>
        <td>
          <%= p.label_full %>
          <% if (p.has_open_session) { %><span class="badge-open">caixa aberto</span><% } %>
        </td>
        <td><%= p.sessions_count %></td>
        <td><%= p.sales_count %></td>
        <td><%= formatMoney(p.pix_cents) %></td>
        <td><%= formatMoney(p.cash_cents) %></td>
        <td><%= formatMoney(p.credit_cents) %></td>
        <td><%= formatMoney(p.total_cents) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>

<% if (points.length) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
  (function () {
    const points = <%- JSON.stringify(points) %>;
    const labels = points.map((p) => p.label);
    const toReais = (cents) => Number(cents || 0) / 100;

    const ctx = document.getElementById('salesByOpeningChart');
    if (!ctx || typeof Chart === 'undefined') return;

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [
          {
            label: 'PIX',
            data: points.map((p) => toReais(p.pix_cents)),
            backgroundColor: 'rgba(212, 175, 55, 0.85)',
            borderColor: '#d4af37',
            borderWidth: 1,
            borderRadius: 6,
            stack: 'sales',
          },
          {
            label: 'Dinheiro',
            data: points.map((p) => toReais(p.cash_cents)),
            backgroundColor: 'rgba(61, 139, 90, 0.8)',
            borderColor: '#3d8b5a',
            borderWidth: 1,
            borderRadius: 6,
            stack: 'sales',
          },
          {
            label: 'Fiado',
            data: points.map((p) => toReais(p.credit_cents)),
            backgroundColor: 'rgba(168, 155, 122, 0.75)',
            borderColor: '#a89b7a',
            borderWidth: 1,
            borderRadius: 6,
            stack: 'sales',
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            labels: { color: '#f5f0e6', boxWidth: 14 },
          },
          tooltip: {
            callbacks: {
              title(items) {
                const idx = items[0]?.dataIndex ?? 0;
                return points[idx]?.label_full || '';
              },
              label(ctx) {
                const value = Number(ctx.parsed.y || 0);
                return (
                  ctx.dataset.label +
                  ': ' +
                  value.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })
                );
              },
              footer(items) {
                const idx = items[0]?.dataIndex ?? 0;
                const p = points[idx];
                if (!p) return '';
                const total = toReais(p.total_cents).toLocaleString('pt-BR', {
                  style: 'currency',
                  currency: 'BRL',
                });
                return p.sales_count + ' venda(s) · Total ' + total;
              },
            },
          },
        },
        scales: {
          x: {
            stacked: true,
            ticks: { color: '#a89b7a' },
            grid: { color: 'rgba(42, 42, 42, 0.6)' },
          },
          y: {
            stacked: true,
            beginAtZero: true,
            ticks: {
              color: '#a89b7a',
              callback(value) {
                return Number(value).toLocaleString('pt-BR', {
                  style: 'currency',
                  currency: 'BRL',
                  maximumFractionDigits: 0,
                });
              },
            },
            grid: { color: 'rgba(42, 42, 42, 0.6)' },
          },
        },
      },
    });
  })();
</script>
<% } %>
<%- include('../partials/layout-bottom') %>
