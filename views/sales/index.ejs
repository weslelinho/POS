<%- include('../partials/layout-top') %>
<section>
  <div class="page-head">
    <h1>Vendas</h1>
    <div class="actions">
      <a class="btn" href="/sales/export.pdf?from=<%= fromDate %>&to=<%= toDate %>">Exportar PDF</a>
      <a class="btn primary" href="/sales/new">Nova venda</a>
    </div>
  </div>

  <form method="get" action="/sales" class="filter-bar">
    <label>De
      <input type="date" name="from" value="<%= fromDate %>" required />
    </label>
    <label>Até
      <input type="date" name="to" value="<%= toDate %>" required />
    </label>
    <button class="btn primary" type="submit">Filtrar</button>
  </form>

  <div class="stats">
    <div class="stat">
      <span class="label">PIX</span>
      <strong><%= formatMoney(summary.pix_cents) %></strong>
    </div>
    <div class="stat">
      <span class="label">Dinheiro</span>
      <strong><%= formatMoney(summary.cash_cents) %></strong>
    </div>
    <div class="stat">
      <span class="label">Fiado</span>
      <strong><%= formatMoney(summary.credit_cents) %></strong>
    </div>
    <div class="stat">
      <span class="label">Total · <%= summary.sales_count %> venda(s)</span>
      <strong><%= formatMoney(summary.total_cents) %></strong>
    </div>
  </div>

  <% if (!sales.length) { %>
  <p class="muted">Nenhuma venda no período selecionado.</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>Nº</th>
        <th>Data</th>
        <th>Cliente</th>
        <th>Vendedor</th>
        <th>Pagamento</th>
        <th>Status pag.</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <% sales.forEach(s => { %>
      <tr>
        <td><%= s.sale_number %></td>
        <td><%= s.sold_at %></td>
        <td><%= s.customer_name || 'Avulso' %></td>
        <td><%= s.seller_name %></td>
        <td>
          <% if (s.payment_method === 'cash') { %>Dinheiro
          <% } else if (s.payment_method === 'pix') { %>PIX
          <% } else { %>Fiado<% } %>
        </td>
        <td>
          <% if (s.payment_status === 'paid') { %>Pago
          <% } else if (s.payment_status === 'credit') { %>Em aberto
          <% } else { %>Parcial<% } %>
        </td>
        <td><%= formatMoney(s.total_cents) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>
<%- include('../partials/layout-bottom') %>
