<%- include('../partials/layout-top') %>
<section>
  <h1>Nova venda</h1>
  <% if (error) { %><div class="alert error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert ok"><%= success %></div><% } %>

  <form id="sale-form" method="post" action="/sales" class="sale-grid">
    <div>
      <h2>Itens</h2>
      <div class="product-list">
        <% products.forEach(p => { %>
        <button
          type="button"
          class="product-card"
          data-id="<%= p.id %>"
          data-name="<%= p.name %>"
          data-price="<%= p.price_cents %>"
        >
          <span class="product-card-media">
            <% if (p.image_path) { %>
              <img src="/public/<%= p.image_path %>" alt="" loading="lazy" />
            <% } else { %>
              <span class="product-card-placeholder" aria-hidden="true"><%= (p.name || '?').charAt(0).toUpperCase() %></span>
            <% } %>
          </span>
          <strong class="product-card-name"><%= p.name %></strong>
          <span class="product-card-price"><%= formatMoney(p.price_cents) %></span>
        </button>
        <% }) %>
      </div>
      <% if (!products.length) { %>
        <p class="muted">Nenhum produto ativo. Cadastre produtos antes de vender.</p>
      <% } %>
      <table id="cart">
        <thead>
          <tr><th>Produto</th><th>Qtd</th><th>Total</th><th></th></tr>
        </thead>
        <tbody></tbody>
      </table>
      <p class="total">Total: <strong id="cart-total">R$ 0,00</strong></p>
    </div>

    <div class="card-form">
      <h2>Pagamento</h2>
      <label>Forma *
        <select name="payment_method" id="payment_method" required>
          <option value="cash">Dinheiro</option>
          <option value="pix">PIX</option>
          <option value="credit">Fiado (membro)</option>
        </select>
      </label>
      <label>Cliente (obrigatório no fiado)
        <input
          type="search"
          id="customer_filter"
          placeholder="Filtrar por nome ou apelido…"
          autocomplete="off"
        />
        <select name="customer_id" id="customer_id" size="8">
          <option value="">— Avulso / sem cadastro —</option>
          <optgroup label="Membros">
            <% members.forEach(m => { %>
              <option value="<%= m.id %>" data-member="1" data-search="<%= (m.name + ' ' + (m.club_nickname || '')).toLowerCase() %>"><%= m.name %><%= m.club_nickname ? ' (' + m.club_nickname + ')' : '' %></option>
            <% }) %>
          </optgroup>
          <optgroup label="Externos">
            <% externals.forEach(e => { %>
              <option value="<%= e.id %>" data-member="0" data-search="<%= e.name.toLowerCase() %>"><%= e.name %></option>
            <% }) %>
          </optgroup>
        </select>
      </label>

      <div id="cash-helper" class="cash-helper">
        <label>Valor em dinheiro (R$)
          <input
            type="text"
            name="cash_received"
            id="cash_received"
            inputmode="decimal"
            placeholder="Ex: 50,00"
            autocomplete="off"
          />
        </label>
        <div id="cash-feedback" class="cash-feedback" hidden></div>
        <label id="remainder-credit-wrap" class="checkbox-row" hidden>
          <input type="checkbox" name="remainder_as_credit" id="remainder_as_credit" value="1" />
          <span>Lançar valor faltante no fiado do membro</span>
        </label>
        <p id="cash-helper-hint" class="muted cash-helper-hint">
          Digite o valor recebido para calcular troco ou o que falta.
        </p>
      </div>

      <div id="pix-helper" class="pix-helper" hidden>
        <p class="pix-helper-title">Pagamento via PIX</p>
        <img
          class="pix-qr"
          src="/public/img/pix-qrcode.png"
          alt="QR Code PIX — SCAN ME"
          width="264"
          height="312"
        />
        <div class="pix-key-block">
          <span class="muted">Chave PIX</span>
          <code id="pix-key-value">+5561996160566</code>
          <button type="button" class="btn ghost" id="btn-copy-pix" data-pix-key="+5561996160566">
            Copiar chave
          </button>
        </div>
        <p class="muted pix-helper-hint">Mostre o QR ao cliente ou copie a chave para colar no app do banco.</p>
      </div>

      <label>Observações
        <textarea name="notes"></textarea>
      </label>
      <input type="hidden" name="items" id="items-json" value="[]" />
      <button class="btn primary" id="btn-finish" type="submit">Finalizar venda</button>
    </div>
  </form>
</section>
<script>
  const cart = new Map();
  const tbody = document.querySelector('#cart tbody');
  const totalEl = document.querySelector('#cart-total');
  const itemsInput = document.querySelector('#items-json');
  const form = document.querySelector('#sale-form');
  const finishBtn = document.querySelector('#btn-finish');
  const paymentMethodEl = document.querySelector('#payment_method');
  const customerEl = document.querySelector('#customer_id');
  const customerFilterEl = document.querySelector('#customer_filter');
  const cashHelper = document.querySelector('#cash-helper');
  const pixHelper = document.querySelector('#pix-helper');
  const cashReceivedEl = document.querySelector('#cash_received');
  const cashFeedback = document.querySelector('#cash-feedback');
  const remainderWrap = document.querySelector('#remainder-credit-wrap');
  const remainderCreditEl = document.querySelector('#remainder_as_credit');
  const btnCopyPix = document.querySelector('#btn-copy-pix');

  let cartTotalCents = 0;

  function money(cents) {
    return (Number(cents) / 100).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
  }

  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function parseMoneyToCents(raw) {
    const text = String(raw || '').trim();
    if (!text) return null;
    // 50,00 / 1.250,50 → BR; 50 / 50.00 → ponto decimal
    const normalized = text.includes(',')
      ? text.replace(/\./g, '').replace(',', '.')
      : text;
    const value = Number(normalized);
    if (!Number.isFinite(value) || value < 0) return NaN;
    return Math.round(value * 100);
  }

  function isSelectedMember() {
    const opt = customerEl.selectedOptions[0];
    return Boolean(opt && opt.dataset.member === '1');
  }

  function filterCustomers() {
    const q = String(customerFilterEl.value || '').trim().toLowerCase();
    const selectedValue = customerEl.value;
    let selectedStillVisible = selectedValue === '';

    customerEl.querySelectorAll('optgroup').forEach((group) => {
      let visibleCount = 0;
      group.querySelectorAll('option').forEach((opt) => {
        const haystack = opt.dataset.search || opt.textContent.toLowerCase();
        const match = !q || haystack.includes(q);
        opt.hidden = !match;
        if (match) visibleCount += 1;
        if (match && opt.value === selectedValue) selectedStillVisible = true;
      });
      group.hidden = visibleCount === 0;
    });

    if (!selectedStillVisible) {
      customerEl.value = '';
      updatePaymentHelpers();
    }
  }

  function updatePaymentHelpers() {
    const method = paymentMethodEl.value;
    const isCash = method === 'cash';
    const isPix = method === 'pix';

    cashHelper.hidden = !isCash;
    pixHelper.hidden = !isPix;

    if (!isCash) {
      cashFeedback.hidden = true;
      remainderWrap.hidden = true;
      remainderCreditEl.checked = false;
    }

    if (!isCash) return;

    const received = parseMoneyToCents(cashReceivedEl.value);
    if (received === null) {
      cashFeedback.hidden = true;
      cashFeedback.textContent = '';
      cashFeedback.className = 'cash-feedback';
      remainderWrap.hidden = true;
      remainderCreditEl.checked = false;
      return;
    }

    if (Number.isNaN(received)) {
      cashFeedback.hidden = false;
      cashFeedback.className = 'cash-feedback is-error';
      cashFeedback.textContent = 'Valor inválido.';
      remainderWrap.hidden = true;
      return;
    }

    cashFeedback.hidden = false;
    const diff = received - cartTotalCents;

    if (cartTotalCents <= 0) {
      cashFeedback.className = 'cash-feedback';
      cashFeedback.textContent = 'Adicione itens para calcular.';
      remainderWrap.hidden = true;
      return;
    }

    if (diff > 0) {
      cashFeedback.className = 'cash-feedback is-change';
      cashFeedback.innerHTML = `Troco a devolver: <strong>${money(diff)}</strong>`;
      remainderWrap.hidden = true;
      remainderCreditEl.checked = false;
      return;
    }

    if (diff === 0) {
      cashFeedback.className = 'cash-feedback is-exact';
      cashFeedback.textContent = 'Valor exato — sem troco.';
      remainderWrap.hidden = true;
      remainderCreditEl.checked = false;
      return;
    }

    const missing = -diff;
    cashFeedback.className = 'cash-feedback is-missing';
    cashFeedback.innerHTML = `Faltam <strong>${money(missing)}</strong>`;

    if (isSelectedMember()) {
      remainderWrap.hidden = false;
    } else {
      remainderWrap.hidden = true;
      remainderCreditEl.checked = false;
      cashFeedback.innerHTML += '. Selecione um membro para lançar o restante no fiado.';
    }
  }

  function syncItems() {
    const items = [];
    let total = 0;
    for (const [id, row] of cart) {
      items.push({ product_id: Number(id), quantity: row.qty });
      total += row.price * row.qty;
    }
    itemsInput.value = JSON.stringify(items);
    cartTotalCents = total;
    totalEl.textContent = money(total);
    updatePaymentHelpers();
    return items;
  }

  function render() {
    tbody.innerHTML = '';
    for (const [id, row] of cart) {
      const line = row.price * row.qty;
      const tr = document.createElement('tr');
      tr.innerHTML = `<td>${escapeHtml(row.name)}</td>
        <td><input type="number" min="1" value="${row.qty}" data-id="${id}" class="qty" /></td>
        <td>${money(line)}</td>
        <td><button type="button" data-remove="${id}" class="btn ghost">✕</button></td>`;
      tbody.appendChild(tr);
    }
    syncItems();
  }

  document.querySelectorAll('.product-card').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.id;
      const current = cart.get(id) || {
        name: btn.dataset.name,
        price: Number(btn.dataset.price),
        qty: 0,
      };
      current.qty += 1;
      cart.set(id, current);
      render();
    });
  });

  tbody.addEventListener('input', (e) => {
    if (!e.target.classList.contains('qty')) return;
    const id = e.target.dataset.id;
    const row = cart.get(id);
    if (!row) return;
    row.qty = Math.max(1, Number(e.target.value) || 1);
    cart.set(id, row);
    syncItems();
  });

  tbody.addEventListener('change', (e) => {
    if (!e.target.classList.contains('qty')) return;
    const id = e.target.dataset.id;
    const row = cart.get(id);
    if (!row) return;
    row.qty = Math.max(1, Number(e.target.value) || 1);
    e.target.value = row.qty;
    cart.set(id, row);
    render();
  });

  tbody.addEventListener('keydown', (e) => {
    if (e.target.classList.contains('qty') && e.key === 'Enter') {
      e.preventDefault();
      e.target.blur();
    }
  });

  tbody.addEventListener('click', (e) => {
    const id = e.target.dataset.remove;
    if (id) {
      cart.delete(id);
      render();
    }
  });

  paymentMethodEl.addEventListener('change', updatePaymentHelpers);
  customerEl.addEventListener('change', updatePaymentHelpers);
  customerFilterEl.addEventListener('input', filterCustomers);
  cashReceivedEl.addEventListener('input', updatePaymentHelpers);
  remainderCreditEl.addEventListener('change', updatePaymentHelpers);

  btnCopyPix.addEventListener('click', async () => {
    const key = btnCopyPix.dataset.pixKey || '';
    try {
      await navigator.clipboard.writeText(key);
      const prev = btnCopyPix.textContent;
      btnCopyPix.textContent = 'Copiada!';
      setTimeout(() => { btnCopyPix.textContent = prev; }, 1500);
    } catch {
      window.prompt('Copie a chave PIX:', key);
    }
  });

  form.addEventListener('submit', (e) => {
    syncItems();
    if (cart.size === 0) {
      e.preventDefault();
      alert('Adicione ao menos um produto.');
      return;
    }
    const method = paymentMethodEl.value;
    const customer = customerEl.value;
    if (method === 'credit' && !customer) {
      e.preventDefault();
      alert('Selecione o membro para venda fiado.');
      return;
    }

    if (method === 'cash') {
      const received = parseMoneyToCents(cashReceivedEl.value);
      if (received !== null) {
        if (Number.isNaN(received)) {
          e.preventDefault();
          alert('Valor em dinheiro inválido.');
          return;
        }
        if (received < cartTotalCents) {
          if (!remainderCreditEl.checked) {
            e.preventDefault();
            alert('Valor insuficiente. Informe o valor completo ou lance o restante no fiado (membro).');
            return;
          }
          if (!isSelectedMember()) {
            e.preventDefault();
            alert('Selecione um membro para lançar o valor faltante no fiado.');
            return;
          }
        }
      }
    }

    finishBtn.disabled = true;
    finishBtn.textContent = 'Registrando…';
  });

  updatePaymentHelpers();
</script>
<%- include('../partials/layout-bottom') %>
