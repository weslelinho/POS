<%- include('../partials/layout-top') %>
<section>
  <h1>Fiado em aberto</h1>
  <table>
    <thead>
      <tr>
        <th>Membro</th>
        <th>Apelido</th>
        <th>Telefone</th>
        <th>Saldo</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% if (!accounts.length) { %>
        <tr><td colspan="5">Nenhum fiado em aberto.</td></tr>
      <% } %>
      <% accounts.forEach(a => { %>
      <tr>
        <td><%= a.name %></td>
        <td><%= a.club_nickname || '—' %></td>
        <td><%= a.phone || '—' %></td>
        <td><%= formatMoney(a.balance_cents) %></td>
        <td><a class="btn" href="/credit/<%= a.customer_id %>">Detalhe / quitar</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('../partials/layout-bottom') %>
