<%- include('../partials/layout-top') %>
<section>
  <h1>Fiado em aberto</h1>

  <form method="get" action="/credit" class="filter-bar">
    <label>Buscar cliente
      <input type="search" name="q" value="<%= q || '' %>" placeholder="Nome ou apelido" autocomplete="off" />
    </label>
    <button class="btn primary" type="submit">Filtrar</button>
    <% if (q) { %><a class="btn" href="/credit">Limpar</a><% } %>
  </form>

  <table>
    <thead>
      <tr>
        <th>Membro</th>
        <th>Apelido</th>
        <th>Telefone</th>
        <% if (currentUser.role === 'admin') { %><th>Saldo</th><% } %>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% if (!accounts.length) { %>
        <tr><td colspan="<%= currentUser.role === 'admin' ? 5 : 4 %>"><%= q ? 'Nenhum cliente encontrado com esse nome.' : 'Nenhum fiado em aberto.' %></td></tr>
      <% } %>
      <% accounts.forEach(a => { %>
      <tr>
        <td><%= a.name %></td>
        <td><%= a.club_nickname || '—' %></td>
        <td><%= a.phone || '—' %></td>
        <% if (currentUser.role === 'admin') { %>
          <td><%= formatMoney(a.balance_cents) %></td>
        <% } %>
        <td><a class="btn" href="/credit/<%= a.customer_id %>">Detalhe / quitar</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('../partials/layout-bottom') %>
