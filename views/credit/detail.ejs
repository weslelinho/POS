<%- include('../partials/layout-top') %>
<section>
  <div class="page-head">
    <h1>Fiado — <%= customer.name %></h1>
    <a class="btn" href="/credit">Voltar</a>
  </div>
  <p>Saldo em aberto: <strong><%= formatMoney(account?.balance_cents || 0) %></strong></p>

  <% if (error) { %><div class="alert error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert ok"><%= success %></div><% } %>

  <% if ((account?.balance_cents || 0) > 0) { %>
  <form method="post" action="/credit/<%= customer.id %>/pay" class="card-form">
    <h2>Registrar pagamento</h2>
    <label>Valor (R$) *
      <input name="amount" required placeholder="0,00" />
    </label>
    <label>Forma *
      <select name="payment_method" required>
        <option value="pix">PIX</option>
        <option value="cash">Dinheiro</option>
      </select>
    </label>
    <label>Observações
      <textarea name="notes"></textarea>
    </label>
    <button class="btn primary" type="submit">Quitar</button>
  </form>
  <% } %>

  <h2>Extrato</h2>
  <table class="ledger-table">
    <thead>
      <tr>
        <th>Data</th>
        <th>Tipo</th>
        <th>Valor</th>
        <th>Pagamento</th>
        <th>Saldo após</th>
        <th>Obs.</th>
      </tr>
    </thead>
    <tbody>
      <% ledger.forEach(l => { %>
      <tr class="ledger-row">
        <td><%= l.created_at %></td>
        <td>
          <% if (l.entry_type === 'charge') { %>Cobrança
          <% } else if (l.entry_type === 'payment') { %>Pagamento
          <% } else { %>Ajuste<% } %>
        </td>
        <td><%= formatMoney(l.amount_cents) %></td>
        <td><%= l.payment_method || '—' %></td>
        <td><%= formatMoney(l.balance_after_cents) %></td>
        <td><%= l.notes || '—' %></td>
      </tr>
      <% if (l.entry_type === 'charge' && l.items && l.items.length) { %>
      <tr class="ledger-items-row">
        <td colspan="6">
          <div class="charge-items">
            <div class="charge-items-head">
              <strong>Itens da cobrança<% if (l.sale?.sale_number) { %> — <%= l.sale.sale_number %><% } %></strong>
              <% if (l.sale) { %>
              <span class="muted">
                Total venda: <%= formatMoney(l.sale.total_cents) %>
                <% if (l.sale.discount_cents > 0) { %> · Desconto: <%= formatMoney(l.sale.discount_cents) %><% } %>
                <% if (l.sale.amount_paid_cents > 0) { %> · Pago na hora: <%= formatMoney(l.sale.amount_paid_cents) %><% } %>
                · Fiado: <%= formatMoney(l.amount_cents) %>
              </span>
              <% } %>
            </div>
            <table class="items-table">
              <thead>
                <tr>
                  <th>Produto</th>
                  <th>Qtd</th>
                  <th>Preço unit.</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <% l.items.forEach(item => { %>
                <tr>
                  <td><%= item.product_name %></td>
                  <td><%= item.quantity %></td>
                  <td><%= formatMoney(item.unit_price_cents) %></td>
                  <td><%= formatMoney(item.line_total_cents) %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </td>
      </tr>
      <% } else if (l.entry_type === 'charge' && l.sale_id) { %>
      <tr class="ledger-items-row">
        <td colspan="6">
          <div class="charge-items">
            <span class="muted">Nenhum item encontrado para esta cobrança.</span>
          </div>
        </td>
      </tr>
      <% } %>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('../partials/layout-bottom') %>
