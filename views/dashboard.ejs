<%- include('partials/layout-top') %>
<section>
  <h1>Painel</h1>
  <div class="stats">
    <div class="stat">
      <span class="label">Vendas hoje</span>
      <strong><%= stats.salesToday.c %></strong>
      <small><%= formatMoney(stats.salesToday.total) %></small>
    </div>
    <div class="stat">
      <span class="label">Fiado em aberto</span>
      <strong><%= formatMoney(stats.creditOpen.total) %></strong>
    </div>
    <div class="stat">
      <span class="label">Produtos ativos</span>
      <strong><%= stats.products.c %></strong>
    </div>
    <div class="stat">
      <span class="label">Membros</span>
      <strong><%= stats.members.c %></strong>
    </div>
    <div class="stat">
      <span class="label">Caixa</span>
      <% if (stats.cashOpen) { %>
      <strong>Aberto</strong>
      <small>esperado <%= formatMoney(stats.cashExpected) %></small>
      <% } else { %>
      <strong>Fechado</strong>
      <small>abra com fundo de troco</small>
      <% } %>
    </div>
  </div>
  <div class="actions">
    <a class="btn primary" href="/sales/new">Nova venda</a>
    <a class="btn" href="/cash">Caixa</a>
    <a class="btn" href="/credit">Ver fiado</a>
  </div>
</section>
<%- include('partials/layout-bottom') %>
